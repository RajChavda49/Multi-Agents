PORT=3001
OLLAMA_BASE_URL=http://localhost:11434
# A1–A3 planning: pull `ollama pull qwen2.5:3b` (much faster on CPU than 7B coder)
OLLAMA_PLANNING_MODEL=qwen2.5:3b
OLLAMA_PLANNING_MODE=llm
OLLAMA_PLANNING_TIMEOUT_MS=300000
OLLAMA_WARMUP_MS=10000
OLLAMA_WARMUP=true
SKIP_A5=true
OLLAMA_CODING_MODEL=qwen2.5-coder
OLLAMA_REASONING_MODEL=qwen2.5-coder
OLLAMA_TIMEOUT_MS=600000
# Gemini free tier — get key at https://aistudio.google.com/apikey (starts with AIza…)
LLM_PROVIDER=gemini
LLM_CODING_PROVIDER=gemini
GOOGLE_API_KEY=your-ai-studio-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_CODING_MODEL=gemini-2.0-flash
DATA_DIR=./data
TARGET_REPO_PATH=/home/cp/cp_projects/bannerbuzz-nextjs
# Write generated code into that folder (true) or sandbox only (false)
TARGET_REPO_WRITE=true

# GitHub — preferred when GitLab is not set (clone → branch sdlc/{JIRA-KEY} → push + PR)
GITHUB_BASE_URL=https://github.com
GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_PROJECT_PATH=owner/repo
# or full URL: https://github.com/owner/repo
GITHUB_DEFAULT_BRANCH=main
GITHUB_WRITE=true
GITHUB_CREATE_MR=true

# GitLab — preferred code target (clone → branch per Jira task → push + MR)
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=your-gitlab-personal-access-token
GITLAB_PROJECT_PATH=group/project
GITLAB_DEFAULT_BRANCH=main
GITLAB_WRITE=true
GITLAB_CREATE_MR=true

# Jira Cloud — site URL only (no /rest/api path)
# Token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-site.atlassian.net/rest/api/3
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-atlassian-api-token
JIRA_PROJECT_KEY=KAN

# Jira description images (optional)
# JIRA_IMAGE_MAX_COUNT=6
# JIRA_IMAGE_MAX_BYTES=5242880
